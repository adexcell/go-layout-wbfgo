# App
APP_NAME=my-app
APP_VERSION=v0.1.1

# HTTP
HTTP_HOST=localhost
HTTP_PORT=8080

# GIN
GIN_MODE=release

# Logger
LOGGER_PRETTY_CONSOLE=true
LOGGER_LEVEL=debug

# OTEL
OTEL_ENDPOINT=localhost:4317
OTEL_NAMESPACE=dev
OTEL_INSTANCE_ID=1

# Postgres
POSTGRES_USER=login
POSTGRES_PASSWORD=pass
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_DB_NAME=postgres

# Redis
REDIS_ADDR=localhost:6379

# Kafka
KAFKA_WRITER_ADDR=localhost:9094
KAFKA_CONSUMER_ADDR=localhost:9094

# Rabbit
RABBIT_HOST=rabbitmq
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBIT_EXCHANGE=notifications.exchange
RABBIT_QUEUE_NAME=notifications
RABBIT_DLX_NAME=notifications.dlx
RABBIT_DLQ_NAME=notifications.dlq


# MAILER
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_EMAIL=yours@gmail.com
MAILER_PASSWORD=yours
MAILER_USE_TLS=true
MAILER_SEND_TIMEOUT=10s
